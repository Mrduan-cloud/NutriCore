# ====== App ======
APP_NAME=NutriCore
APP_ENV=dev
LOG_LEVEL=INFO
LOG_JSON=false
CORS_ORIGINS=["*"]

# ====== Security (生产必须改) ======
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 每用户独立口令(bcrypt)+ 角色化 JWT。以下仅用于「启动 seed」与登录保护:
# - DEMO_PASSWORD: 启动时为演示人设(李哲/林悦)设置的口令,仅体验用
# - ADMIN_USERNAME/ADMIN_PASSWORD: 启动时引导的管理员账号(生产务必改 ADMIN_PASSWORD)
# - 连续失败 N 次锁定 M 分钟,挡暴力撞库
# APP_ENV=prod 时,若 JWT_SECRET_KEY/ADMIN_PASSWORD/MYSQL_PASSWORD 仍是默认值 → 拒绝启动
DEMO_PASSWORD=nutricore2024
ADMIN_USERNAME=admin
ADMIN_PASSWORD=nutricore-admin-2024
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ====== LLM ======
# 默认配置：vLLM 私有化部署 Qwen2.5-32B-Instruct-AWQ
#   2× RTX 4090 24G + Tensor Parallel (TP=2)，AWQ Int4 量化让 32B 显存压到 ~20GB
#   启动命令见 docs/DEPLOYMENT.md §2.5
# 开发机如果没有 4090，可以临时换成 Ollama 跑小模型，见 .env.example 注释
LLM_BASE_URL=http://host.docker.internal:8001/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.3

# ====== Embedding & Reranker ======
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DIM=1024
MODEL_CACHE_DIR=/app/.cache/models

# ====== Milvus ======
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_FOOD=food_kb
MILVUS_COLLECTION_GUIDE=dietary_guide_kb

# ====== MySQL ======
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=nutricore
MYSQL_PASSWORD=changeme
MYSQL_DB=nutricore
MYSQL_ROOT_PASSWORD=root

# ====== Redis ======
REDIS_URL=redis://redis:6379/0

# ====== MinIO ======
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nutricore
MINIO_SECURE=false

# ====== Dify (可选 - 数据洞察可视化编排) ======
DIFY_API_BASE=http://dify-api:8080/v1
DIFY_API_KEY=
DIFY_WORKFLOW_ID=nl2sql_insight

# ====== Vanna.ai (可选) ======
VANNA_API_KEY=
VANNA_MODEL=nutricore-sql

# ====== Observability ======
METRICS_ENABLED=true
METRICS_PATH=/metrics
SENTRY_DSN=

# ====== 没有 4090 的开发机替代方案（取消注释覆盖即可） ======
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b-instruct
